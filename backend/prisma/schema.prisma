generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarColor  String   @default("#FF6B4A")
  createdAt    DateTime @default(now())

  meetingsHosted Meeting[]      @relation("HostedMeetings")
  participations Participant[]
}

model Meeting {
  id        String    @id @default(uuid())
  code      String    @unique // e.g. abc-defg-hjk, shown to users
  title     String    @default("Untitled meeting")
  hostId    String
  host      User      @relation("HostedMeetings", fields: [hostId], references: [id])
  locked    Boolean   @default(false)
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  participants Participant[]
  recordings   Recording[]
  transcripts  Transcript[]
}

model Participant {
  id          String    @id @default(uuid())
  meetingId   String
  meeting     Meeting   @relation(fields: [meetingId], references: [id])
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  displayName String
  isAnonymous Boolean   @default(false)
  role        String    @default("participant") // host | cohost | participant
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?
}

model Recording {
  id          String   @id @default(uuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id])
  storageKey  String   // file path inside the MinIO bucket
  durationSec Int?
  createdAt   DateTime @default(now())
}

model Transcript {
  id          String   @id @default(uuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id])
  summary     String?  @db.Text
  actionItems Json?
  fullText    String?  @db.Text
  createdAt   DateTime @default(now())
}